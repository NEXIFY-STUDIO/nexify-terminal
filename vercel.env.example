# Nexify Terminal — Vercel Production environment variables
# Copy values into Vercel Dashboard → Project → Settings → Environment Variables
# or sync from local .env.local:  bash scripts/sync-vercel-env.sh
#
# NEVER commit real secrets. This file is a template only.

# ── Required for UI (baked into client bundle at build time) ────────────────
NEXT_PUBLIC_PASSCODE=2366

# ── Public Vercel deploy: disable Tailscale IP lockdown ─────────────────────
DISABLE_TAILSCALE_LOCKDOWN=true

# ── Auth (server-side) ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=change-me-nextauth-secret

# ── Next.js API proxies → backend services ───────────────────────────────────
# On Vercel cloud, 127.0.0.1 backends are NOT reachable.
# Full Nexify (shell + AI) requires the Mac stack via Tailscale on :3322.
# Optional: point to Mac via Tailscale Funnel/Serve URLs if you expose backends.
HACK_API_URL=http://127.0.0.1:3021
AI_PROXY_URL=http://127.0.0.1:8788
HACK_API_TOKEN=change-me-hack-token
SHELL_TOKEN=change-me-shell-token

# ── AI provider (used by ai-proxy when deployed alongside Next) ─────────────
AI_PROVIDER=mistral
MISTRAL_API_KEY_1=your-mistral-primary-key
MISTRAL_API_KEY_2=your-mistral-backup-key
MISTRAL_MODEL=mistral-small-latest