# ─────────────────────────────────────────────────────────────────────────────
# Nexify Terminal — Phase 1 environment example
# Copy to .env.local (Next + scripts) and fill in real values. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Next route handlers -> backend services ─────────────────────────────────
# URLs the Next /api/{tools,shell,ai} proxies forward to.
HACK_API_URL=http://127.0.0.1:3021
AI_PROXY_URL=http://127.0.0.1:8788

# Server-side tokens injected by the Next proxies. NEVER exposed to the client.
# Generate with: openssl rand -hex 32
HACK_API_TOKEN=change-me-hack-token
SHELL_TOKEN=change-me-shell-token

# ── hacking API service (services/hacking-api/server.js) ────────────────────
# NOTE: legacy default PORT is 3001; dev-all.sh runs hacking API on 3021.
PORT=3021
ALLOWED_ORIGIN=http://localhost:3322,http://127.0.0.1:3322,http://100.103.153.97:3322
# Comma-separated allowlist of directories the remote shell may cd into.
SHELL_CWD_ALLOWLIST=/home/youruser/projects
# Optional shell tuning (defaults shown):
# SHELL_COMMAND=/bin/bash
# SHELL_USE_PTY=1
# SHELL_MAX_SESSIONS=2
# SHELL_IDLE_TIMEOUT_MS=900000
# SHELL_RATE_LIMIT_MAX=600

# ── AI proxy service (services/ai-proxy/ai-proxy.mjs) ───────────────────────
AI_PROXY_HOST=0.0.0.0
AI_PROXY_PORT=8788
# Allowed browser origin for the AI proxy CORS (Next UI calls it via the proxy,
# but set this if you hit the AI proxy directly during dev).
AI_ALLOWED_ORIGIN=http://localhost:3322
# Provider: github-models | mistral | gemini | gamma
AI_PROVIDER=github-models
# AI provider keys — set the one matching AI_PROVIDER:
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini
# GITHUB_MODELS_ORG=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
# GEMINI_API_KEY=        # Phase 2 — do not enable yet
# GEMINI_MODEL=gemini-2.5-flash
# GAMMA_API_KEY=         # Gamma 4B4 model
# GAMMA_MODEL=gamma-4b4
# GAMMA_ENDPOINT=https://api.gamma.ai/v1/chat/completions

# ── CSP / dev networking ────────────────────────────────────────────────────
# Extra connect-src origins for dev (comma-separated, no wildcards). Add your
# Tailscale host here so the browser may talk to dev services over Tailscale.
NEXT_PUBLIC_DEV_CONNECT_SRC=http://100.103.153.97:3322,http://100.103.153.97:3021,http://100.103.153.97:8788

# ── Nexify launchd service (auto-start + in-app restart) ────────────────────
# Label of the macOS LaunchAgent that runs scripts/dev-all.sh
NEXIFY_LAUNCHD_LABEL=com.nexify.terminal
# Minimum seconds between /api/restart calls (default 30)
# NEXIFY_RESTART_COOLDOWN_MS=30000

# Extra Next.js dev origins (comma-separated hostnames, appended to allowedDevOrigins)
# NEXIFY_ALLOWED_DEV_ORIGINS=my-other-host.tail8c034f.ts.net

# ── Pandora connector (optional upstream) ───────────────────────────────────
# If unset, /api/pandora/projects/create returns a Phase 1 stub response.
# PANDORA_UPSTREAM_URL=https://pandora.example.com
# PANDORA_API_TOKEN=
# PANDORA_API_ENDPOINT=/api/pandora/projects/create
